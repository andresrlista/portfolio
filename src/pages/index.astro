---
// layout
import Layout from '../layouts/Layout.astro';

// sections
import ProfileSection from './home/ProfileSection.astro';
import ExperienceSection from './home/ExperienceSection.astro';
import ProjectSection from './projects/ProjectSection.astro';
import Divider from '../components/Divider.astro';
---

<Layout title='Andres Lista | Web Developer'>
  <ProfileSection
    id='home'
    title='About me'
    class={`grid grid-cols-1 
    xs:grid-cols-1 sm:grid-cols-1 md:grid-cols-1 lg:grid-cols-2
    place-items-center max-w-6xl gap-8`}
  />
  <Divider id='experience' title='Experience' class='max-w-4xl pt-32' />
  <ExperienceSection
    title='Experience'
    class=`grid grid-cols-1 
    xs:grid-cols-1 sm:grid-cols-1 md:grid-cols-1 lg:grid-cols-1 
    place-items-center max-w-2xl`
  />
  <Divider id='projects' title='Projects' class='max-w-4xl pt-32' />
  <ProjectSection
    title='Projects'
    class={`grid grid-cols-3 
    xs:grid-cols-3 sm:grid-cols-3 md:grid-cols-2 lg:grid-cols-3
    place-items-center max-w-6xl w-full gap-8 mt-24`}
  />
</Layout>
